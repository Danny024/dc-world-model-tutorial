# ============================================================
# STEP 0 — Edit this file before running any other script
# ============================================================
# Replace every value that says YOUR_PROJECT_ID / YOUR_REGION
# with your actual GCP project info.
#
# To find your project ID:
#   gcloud projects list
# ============================================================

# Your GCP project ID (e.g. my-datacenter-twin-001)
export GCP_PROJECT_ID="YOUR_PROJECT_ID"

# GCP region — us-central1 is cheapest for L4 VMs
export GCP_REGION="us-central1"

# GCP zone — must be in the same region
export GCP_ZONE="us-central1-a"

# GCS bucket name for USD assets + training data
# Convention: keep it globally unique by using your project ID as prefix
export GCS_BUCKET="${GCP_PROJECT_ID}-omniverse-assets"

# Artifact Registry repository name (stores your Docker image)
export AR_REPO="omniverse-kit"

# GPU VM name
export VM_NAME="datacenter-kit-vm"

# VM machine type:
#   g2-standard-8  = 8 vCPU + 32 GB RAM + 1x NVIDIA L4  (~$0.40/hr)
#   g2-standard-16 = 16 vCPU + 64 GB RAM + 1x NVIDIA L4 (~$0.70/hr)
export VM_MACHINE_TYPE="g2-standard-8"

# VM boot disk size in GB (200 GB gives headroom for container + cache)
export VM_DISK_SIZE="200"

# Docker image tag
export IMAGE_TAG="datacenter-kit:latest"

# Full image URI (auto-built from above vars — do not edit)
export IMAGE_URI="${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT_ID}/${AR_REPO}/${IMAGE_TAG}"

# ── USD Asset Paths ───────────────────────────────────────────────────────────
# Local path to the NVIDIA DataHall USD stage on your machine
export USD_STAGE_LOCAL="/data/Datacenter_NVD@10012/Assets/DigitalTwin/Assets/Datacenter/Facilities/Stages/Data_Hall/DataHall_Full_01.usd"

# GCS destination path (after running 03_upload_assets.sh)
export USD_STAGE_GCS="gs://${GCS_BUCKET}/Datacenter_NVD@10012/Assets/DigitalTwin/Assets/Datacenter/Facilities/Stages/Data_Hall/DataHall_Full_01.usd"

# ── Vertex AI ─────────────────────────────────────────────────────────────────
# Region for Vertex AI training (must support A100 GPUs)
# A100 availability: us-central1, us-east4, europe-west4
export VERTEX_REGION="us-central1"

# GCS paths for training data and saved model files
export TRAINING_DATA_GCS="gs://${GCS_BUCKET}/training-data"
export MODEL_ARTEFACT_GCS="gs://${GCS_BUCKET}/models"
