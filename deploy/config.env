# ============================================================
# STEP 0 — Edit this file before running any other script
# ============================================================
# Replace every value that says YOUR_PROJECT_ID / YOUR_REGION
# with your actual GCP project info.
#
# To find your project ID:
#   gcloud projects list
# ============================================================

# Your GCP project ID (e.g. my-datacenter-twin-001)
export GCP_PROJECT_ID="hmth391"

# GCP region — us-central1 is cheapest for L4 VMs
export GCP_REGION="us-central1"

# GCP zone — must be in the same region
export GCP_ZONE="us-central1-a"

# ── GCS Buckets ───────────────────────────────────────────────────────────────
# Primary bucket: USD assets + training data + model artefacts
export GCS_BUCKET="${GCP_PROJECT_ID}-omniverse-assets"

# Telemetry ingest bucket: real sensor data from Jetson Nano edge devices.
# Scholars write their telemetry pipelines to land CSVs / JSON here.
# This bucket is provisioned externally — do NOT recreate it in 02_gcp_setup.sh.
export GCS_TELEMETRY_BUCKET="hmth391-telemetry-ingest"

# ── Artifact Registry ─────────────────────────────────────────────────────────
# Repo for NVIDIA Kit Streaming container (Phase 4b / 5b)
export AR_REPO_KIT="omniverse-kit"

# Repo for World Model inference image, DINO encoder weights, and edge artefacts.
# This is the registry Jetson Nano edge devices pull from for local inference.
# Provisioned by Nolan: us-central1-docker.pkg.dev/hmth391/world-model-repo
export AR_REPO_MODELS="world-model-repo"

# ── Image URIs ────────────────────────────────────────────────────────────────
# Kit streaming container (Phase 4b — NVIDIA usd-viewer image)
export KIT_IMAGE_URI="${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT_ID}/${AR_REPO_KIT}/usd-viewer:latest"

# Inference server image (Phase 4 — CPU Flask container, also deployed to Jetson)
export IMAGE_TAG="datacenter-inference:latest"
export IMAGE_URI="${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT_ID}/${AR_REPO_MODELS}/${IMAGE_TAG}"

# DINO encoder weights image (edge deployment artefact)
export DINO_IMAGE_TAG="dino-encoder:latest"
export DINO_IMAGE_URI="${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT_ID}/${AR_REPO_MODELS}/${DINO_IMAGE_TAG}"

# ── GPU VM ────────────────────────────────────────────────────────────────────
export VM_NAME="datacenter-kit-vm"

# VM machine type:
#   g2-standard-8  = 8 vCPU + 32 GB RAM + 1x NVIDIA L4  (~$0.40/hr)
#   g2-standard-16 = 16 vCPU + 64 GB RAM + 1x NVIDIA L4 (~$0.70/hr)
export VM_MACHINE_TYPE="g2-standard-8"

# VM boot disk size in GB (200 GB gives headroom for container + cache)
export VM_DISK_SIZE="200"

# ── USD Asset Paths ───────────────────────────────────────────────────────────
# Local path to the root of the DigitalTwin asset library on your machine.
# Windows path (using forward slashes — works in bash/Git Bash/WSL):
export USD_ASSETS_LOCAL_WIN="C:/Users/danie/OneDrive/Assets/DigitalTwin"
# Bash-friendly path (used by scripts running in Git Bash / MSYS2):
export USD_ASSETS_LOCAL="/c/Users/danie/OneDrive/Assets/DigitalTwin"

# Path to the top-level stage file (relative to USD_ASSETS_LOCAL)
export USD_STAGE_RELATIVE="Assets/Datacenter/Facilities/Stages/Data_Hall/DataHall_Full_01.usd"
export USD_STAGE_LOCAL="${USD_ASSETS_LOCAL}/${USD_STAGE_RELATIVE}"

# GCS destination — the entire DigitalTwin folder is uploaded once
export USD_ASSETS_GCS="gs://${GCS_BUCKET}/DigitalTwin"
export USD_STAGE_GCS="${USD_ASSETS_GCS}/${USD_STAGE_RELATIVE}"

# ── Vertex AI ─────────────────────────────────────────────────────────────────
# Region for Vertex AI training (must support A100 GPUs)
# A100 availability: us-central1, us-east4, europe-west4
export VERTEX_REGION="us-central1"

# ── GCS Data Paths ────────────────────────────────────────────────────────────
# Synthetic training data (generated by Phase 6)
export TRAINING_DATA_GCS="gs://${GCS_BUCKET}/training-data"

# Live / real telemetry landing zone (written by Jetson Nano pipelines)
# Use this as input to Phase 7/8 once real data is available
export LIVE_TELEMETRY_GCS="gs://${GCS_TELEMETRY_BUCKET}"

# Trained model artefacts (checkpoints, ONNX exports, DINO weights)
export MODEL_ARTEFACT_GCS="gs://${GCS_BUCKET}/models"

# Edge deployment artefact path (pulled by Jetson Nano devices)
export EDGE_MODEL_GCS="gs://${GCS_BUCKET}/models/edge"
